DISCORD_TOKEN=your-bot-token-here
BOT_PREFIX=!
LOG_LEVEL=INFO
BOT_LANGUAGE=zh-TW

# Guild ID for instant slash command sync (optional, recommended for dev)
GUILD_ID=

# Auto-voice channel settings
# Leave localized names blank to use BOT_LANGUAGE defaults.
# Set explicit values only when you want to override.
AUTO_VOICE_TRIGGER=
AUTO_VOICE_SUFFIX=
AUTO_VOICE_LIMIT=6

# Private room settings
PRIVATE_CATEGORY=
PRIVATE_TRIGGER=
PRIVATE_SUFFIX=
PRIVATE_LIMIT=4
PASSWORD_CHANNEL=

# Skill settings
SKILL_PREFIX=
SKILL_PANEL_CHANNEL=
# Default direct-join skills for /skill panel (comma separated)
SKILL_PANEL_DIRECT_JOIN_SKILLS=鍛造術,遊戲術,墨繪術,幻想術

# Leveling settings
LEVELING_DB_PATH=data/leveling.db
XP_PER_MESSAGE_MIN=15
XP_PER_MESSAGE_MAX=25
XP_MESSAGE_COOLDOWN=60
XP_PER_VOICE_TICK=10
XP_VOICE_INTERVAL=300
XP_DAILY_BASE=50
LEVELUP_CHANNEL=
# Level milestones:JSON format — [level, "role_name", "#HEX_COLOR"]
# Modify the roles, names and colors below as needed.
# Leave blank to use language-specific defaults.
LEVEL_ROLES=
